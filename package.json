{
  "name": "@adametherzlab/ts-task",
  "version": "0.1.1",
  "description": "Minimal TypeScript-native task runner — define async tasks in a `tasks.ts` file and run them by name with clean logs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "tsc --build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "typescript",
    "bun",
    "nodejs",
    "task-runner",
    "cli",
    "build-tool",
    "developer-tools"
  ],
  "author": {
    "name": "AdametherzLab",
    "url": "https://github.com/AdametherzLab"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdametherzLab/ts-task.git"
  },
  "homepage": "https://github.com/AdametherzLab/ts-task#readme",
  "bugs": {
    "url": "https://github.com/AdametherzLab/ts-task/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/AdametherzLab"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false
}